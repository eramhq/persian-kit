{
    "name": "persian-kit",
    "version": "0.9.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "ENTRY=admin vite build -c vite.config.entries.mjs --watch",
        "clean:public": "rm -rf public/css public/js public/fonts",
        "build": "npm run clean:public && npm run build:copy && npm run build:scripts && npm run build:verify",
        "build:copy": "node scripts/copy-assets.mjs",
        "build:scripts": "ENTRY=admin vite build -c vite.config.entries.mjs",
        "build:verify": "node scripts/verify-build.mjs",
        "build:pot": "wp i18n make-pot . languages/persian-kit.pot --slug=persian-kit --domain=persian-kit --skip-js --exclude=packages,tests",
        "dist": "bash scripts/dist.sh"
    },
    "dependencies": {
        "alpinejs": "^3.14"
    },
    "devDependencies": {
        "@fontsource-variable/vazirmatn": "^5.2.8",
        "vite": "^6.2.0"
    }
}
