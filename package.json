{
    "name": "persian-kit",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev:scripts\" \"npm run dev:sass\"",
        "dev:scripts": "ENTRY=admin vite build -c vite.config.entries.mjs --watch",
        "dev:sass": "sass --watch resources/scss/admin.scss:public/css/admin.css resources/scss/frontend.scss:public/css/frontend.css",
        "build": "npm run build:copy && npm run build:scripts && npm run build:sass",
        "build:copy": "node scripts/copy-assets.mjs",
        "build:scripts": "ENTRY=admin vite build -c vite.config.entries.mjs",
        "build:sass": "sass resources/scss/admin.scss:public/css/admin.css resources/scss/frontend.scss:public/css/frontend.css --style=compressed --no-source-map",
        "build:pot": "wp i18n make-pot . languages/persian-kit.pot --slug=persian-kit --domain=persian-kit"
    },
    "dependencies": {
        "alpinejs": "^3.14"
    },
    "devDependencies": {
        "@fontsource-variable/vazirmatn": "^5.2.8",
        "concurrently": "^9.1.0",
        "sass": "^1.83.0",
        "vite": "^6.2.0"
    }
}
